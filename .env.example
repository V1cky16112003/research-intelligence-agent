# --- Database (Neon Postgres in prod, docker-compose locally) ---
DATABASE_URL=postgresql://raguser:ragpass@localhost:5432/ragdb

# --- Redis (Upstash in prod, docker-compose locally) ---
# Local:
REDIS_URL=redis://localhost:6379
# Upstash (prod) — provide these two instead of REDIS_URL:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- LLM (3-tier fallback: Groq -> NVIDIA NIM -> Gemini) ---
GROQ_API_KEY=
NVIDIA_NIM_API_KEY=
GEMINI_API_KEY=

# --- Neo4j AuraDB (knowledge graph — optional, graph_query tool degrades gracefully if unset) ---
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# --- MLflow / DagsHub ---
DAGSHUB_TOKEN=
DAGSHUB_REPO=username/reponame

# --- Embeddings (defaults work, no change needed) ---
EMBED_MODEL=nomic-ai/nomic-embed-text-v2-moe
EMBED_DIM=768
